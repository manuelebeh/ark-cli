{
  "name": "arkctl",
  "version": "0.5.0",
  "description": "Create projects from remote catalogs with enforceable architecture contracts",
  "type": "module",
  "bin": {
    "arkctl": "./bin/arkctl.js"
  },
  "files": [
    "bin",
    "dist",
    "catalog"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "scaffold",
    "architecture",
    "templates",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manuelebeh/ark-cli.git"
  },
  "homepage": "https://github.com/manuelebeh/ark-cli#readme",
  "bugs": {
    "url": "https://github.com/manuelebeh/ark-cli/issues"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "citty": "^0.2.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
